---
const PHONE = "+41793940167";
const steps = [
  {
    number: "1",
    title: "Appel ou prise de rendez-vous",
    description: "Contactez le cabinet par téléphone pour convenir d'un créneau qui vous convient.",
  },
  {
    number: "2",
    title: "Échange sur vos besoins",
    description: "Un premier temps d'écoute pour comprendre vos douleurs, tensions et attentes.",
  },
  {
    number: "3",
    title: "Séance personnalisée",
    description: "Une séance adaptée à votre corps et à vos zones de tension, dans un cadre apaisant.",
  },
  {
    number: "4",
    title: "Conseils et suivi",
    description: "Des recommandations personnalisées et un suivi si nécessaire pour prolonger les bienfaits.",
  },
];
---
 
<section class="py-16 md:py-24 bg-background">
  <div class="container">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-foreground text-center mb-12">
      Comment se passe une séance&nbsp;?
    </h2>
    <div class="max-w-3xl mx-auto mb-12">
      {steps.map((step, i) => (
        <div class="flex gap-6 mb-8 last:mb-0">
          <div class="shrink-0">
            <div class="w-12 h-12 rounded-full bg-cta flex items-center justify-center">
              <span class="font-display text-xl font-bold text-cta-foreground">{step.number}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="w-px h-8 bg-border mx-auto mt-2" />
            )}
          </div>
          <div class="pt-1">
            <h3 class="font-display text-xl font-semibold text-foreground mb-2">{step.title}</h3>
            <p class="font-body text-muted-foreground leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center">
      <a
        href={`tel:${PHONE}`}
        class="inline-flex items-center justify-center gap-2 bg-cta hover:bg-cta-hover text-cta-foreground font-body font-medium text-base px-6 py-3 rounded-lg transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Appeler pour poser vos questions
      </a>
    </div>
  </div>
</section>