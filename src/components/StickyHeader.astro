---
const PHONE = "+41793940167";
const PHONE_DISPLAY = "+41 79 394 01 67";
---
 
<header class="fixed top-0 left-0 right-0 z-50 bg-background/90 backdrop-blur-md border-b border-border">
  <div class="container flex items-center justify-between h-14">
    <span class="font-display text-lg font-semibold text-foreground">
      Laurianne Vibert
    </span>
    <div class="flex items-center gap-3">
      <a
        href={`tel:${PHONE}`}
        onclick="gtag_report_conversion()"
        aria-label="Appeler le cabinet"
        class="hidden sm:block text-sm font-body font-medium text-foreground hover:text-cta transition-colors"
      >
        {PHONE_DISPLAY}
      </a>
      <a
        href={`tel:${PHONE}`}
        onclick="gtag_report_conversion()"
        aria-label="Appeler le cabinet"
        class="inline-flex items-center gap-2 bg-cta hover:bg-cta-hover text-cta-foreground text-sm font-medium px-3 py-1.5 rounded-lg transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="hidden sm:inline">Appeler</span>
      </a>
    </div>
  </div>
</header>