---
const PHONE = "+41793940167";
---
 
<section class="py-16 md:py-24 bg-secondary">
  <div class="container">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-foreground text-center mb-12">
      Le cabinet à Genève
    </h2>
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <div class="bg-background rounded-2xl p-8 shadow-sm mb-6">
          <div class="flex items-start gap-4 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cta shrink-0 mt-1">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="font-body font-semibold text-foreground text-lg">Adresse</p>
              <p class="font-body text-muted-foreground">
                Rue Pedro-Meylan 1, 1208 Genève<br />
                7ème étage – Human4human Coaching &amp; Thérapies<br />
                Quartier de Champel
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cta shrink-0 mt-1">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <div>
              <p class="font-body font-semibold text-foreground text-lg">Horaires</p>
              <p class="font-body text-muted-foreground">
                Lundi – Vendredi : 9h30 – 20h00
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cta shrink-0 mt-1">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <div>
              <p class="font-body font-semibold text-foreground text-lg">Téléphone</p>
              <a href={`tel:${PHONE}`} onclick="gtag_report_conversion()" class="font-body text-cta font-semibold text-lg hover:text-cta-hover transition-colors">
                +41 79 394 01 67
              </a>
            </div>
          </div>
        </div>
        <p class="font-body text-muted-foreground text-sm mb-6">
          Accessible en transports publics (bus, tram). Parking disponible à proximité.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={`tel:${PHONE}`}
            onclick="gtag_report_conversion()"
            class="inline-flex items-center justify-center gap-2 bg-cta hover:bg-cta-hover text-cta-foreground font-body font-medium text-base px-6 py-3 rounded-lg transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Appeler le cabinet
          </a>
          <a
            href={`tel:${PHONE}`}
            onclick="gtag_report_conversion()"
            class="inline-flex items-center justify-center gap-2 bg-transparent border border-cta text-cta hover:bg-cta hover:text-cta-foreground font-body font-medium text-base px-6 py-3 rounded-lg transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Prendre rendez-vous
          </a>
        </div>
      </div>
 
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="/images/cabinet-acces.webp"
          alt="Accès au cabinet de reboutologie à Genève Champel"
          class="w-full h-auto object-cover aspect-16/10"
          width="640"
          height="400"
          loading="lazy"
          decoding="async"
        />
        <div class="bg-background p-4 text-center">
          <p class="font-body text-sm text-muted-foreground">
            Cabinet situé au cœur de Champel, Genève
          </p>
        </div>
      </div>
    </div>
  </div>
</section>