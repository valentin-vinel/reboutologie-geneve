---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Reboutologie Genève – Laurianne Vibert | Cabinet Champel',
  description = 'Reboutologie à Genève – Laurianne Vibert, reboutologue agréée ASCA à Champel. Soulagez vos tensions, douleurs de dos, migraines. Prenez rendez-vous.',
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta name="author" content="Laurianne Vibert" />
    <link rel="canonical" href="https://reboutologie-geneve.ch" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://reboutologie-geneve.ch" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts non-bloquantes -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" />
    </noscript>

    <!-- TODO: remplacer GTM-XXXXXX par le vrai ID -->
    <!-- <script>(function(w,d,s,l,i){...})(window,document,'script','dataLayer','GTM-XXXXXX');</script> -->
  </head>
  <body>
    <slot />
  </body>
</html>