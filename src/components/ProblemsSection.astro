---
const PHONE = "+41793940167";
const problems = [
  { icon: "🦴", label: "Maux de dos", desc: "Soulagement des douleurs dorsales chroniques ou aiguës" },
  { icon: "⚡", label: "Sciatique", desc: "Réduction des douleurs irradiant le long du nerf sciatique" },
  { icon: "🔄", label: "Douleurs chroniques", desc: "Prise en charge des douleurs persistantes et récurrentes" },
  { icon: "💥", label: "Lumbago", desc: "Traitement des blocages lombaires et tours de reins" },
  { icon: "🩻", label: "Hernie discale", desc: "Accompagnement et soulagement des gênes discales" },
  { icon: "⚖️", label: "Déséquilibre du bassin", desc: "Rééquilibrage postural et correction du bassin" },
];
---
 
<section class="py-16 md:py-24 bg-secondary">
  <div class="container">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-foreground text-center mb-4">
      Pour quels problèmes consulter&nbsp;?
    </h2>
    <p class="text-center text-muted-foreground font-body text-lg mb-12 max-w-2xl mx-auto">
      La reboutologie est une approche manuelle traditionnelle qui peut aider à soulager de nombreuses douleurs et tensions du corps.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto mb-12">
      {problems.map((p) => (
        <div class="bg-card rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow border border-border">
          <span class="text-4xl mb-4 block">{p.icon}</span>
          <h3 class="font-display font-bold text-foreground text-lg mb-2">{p.label}</h3>
          <p class="font-body text-muted-foreground text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
    <div class="text-center">
      <a
        href={`tel:${PHONE}`}
        onclick="gtag_report_conversion()"
        class="inline-flex items-center justify-center gap-2 bg-cta hover:bg-cta-hover text-cta-foreground font-body font-medium text-base px-8 py-4 rounded-lg transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Prendre rendez-vous
      </a>
    </div>
  </div>
</section>