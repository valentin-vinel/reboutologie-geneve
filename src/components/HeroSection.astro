---
const PHONE = "+41793940167";
const PHONE_DISPLAY = "+41 79 394 01 67";
---
 
<section class="relative pt-14">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-cabinet.webp"
      alt="Cabinet de reboutologie à Genève"
      class="w-full h-full object-cover"
      width="1920"
      height="1080"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-background/95 via-background/85 to-background/95"></div>
  </div>
 
  <div class="relative z-10 container py-16 md:py-24 lg:py-32 text-center">
    <div class="max-w-3xl mx-auto">
 
      <!-- Card titre -->
      <div class="bg-white/90 backdrop-blur-sm rounded-2xl px-6 md:px-10 py-8 shadow-lg mb-8">
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-tight mb-4">
          Reboutologie à Genève&nbsp;: soulagez vos tensions et douleurs naturellement
        </h1>
        <p class="text-lg md:text-xl font-body text-muted-foreground leading-relaxed">
          Laurianne Vibert vous accueille à Champel pour des séances de reboutologie personnalisées, dans un cadre apaisant et professionnel.
        </p>
      </div>
 
      <!-- Numéro de téléphone -->
      <a
        href={`tel:${PHONE}`}
        onclick="gtag_report_conversion()"
        class="inline-block bg-white/95 backdrop-blur-sm rounded-2xl px-8 py-4 shadow-lg hover:shadow-xl transition-all mb-8"
      >
        <span class="text-3xl md:text-4xl font-display font-bold text-foreground">{PHONE_DISPLAY}</span>
      </a>
 
      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a
          href={`tel:${PHONE}`}
          onclick="gtag_report_conversion()"
          class="inline-flex items-center justify-center gap-2 bg-cta hover:bg-cta-hover text-cta-foreground font-body font-medium text-base px-8 py-4 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Appeler maintenant
        </a>
        <a
          href={`tel:${PHONE}`}
          onclick="gtag_report_conversion()"
          class="inline-flex items-center justify-center gap-2 bg-white text-cta border-2 border-cta hover:bg-cta hover:text-cta-foreground font-body font-medium text-base px-8 py-4 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Prendre rendez-vous
        </a>
      </div>
 
      <!-- Badges -->
      <div class="flex flex-wrap gap-3 justify-center">
        <span class="inline-flex items-center gap-2 bg-sage-light text-sage-dark text-sm font-body font-medium px-4 py-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Agréée ASCA
        </span>
        <span class="inline-flex items-center gap-2 bg-sage-light text-sage-dark text-sm font-body font-medium px-4 py-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Genève · Champel
        </span>
        <span class="inline-flex items-center gap-2 bg-sage-light text-sage-dark text-sm font-body font-medium px-4 py-2 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          Approche personnalisée
        </span>
      </div>
 
    </div>
  </div>
</section>
 