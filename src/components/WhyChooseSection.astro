---
const PHONE = "+41793940167";
const PHONE_DISPLAY = "+41 79 394 01 67";
const qualities = [
  {
    text: "Praticienne identifiée et diplômée",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  },
  {
    text: "Approche humaine et bienveillante",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
  {
    text: "Cabinet à Genève – Champel",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    text: "Agréée ASCA",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
];
---
 
<section class="py-16 md:py-24 bg-background">
  <div class="container">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-foreground text-center mb-12">
      Pourquoi choisir Laurianne Vibert&nbsp;?
    </h2>
    <div class="max-w-4xl mx-auto text-center">
 
      <!-- Photo centrée -->
      <div class="rounded-2xl overflow-hidden shadow-lg max-w-md mx-auto mb-8">
        <img
          src="/images/laurianne-portrait.webp"
          alt="Laurianne Vibert, reboutologue à Genève en séance"
          class="w-full h-auto object-cover aspect-[3/4]"
          width="480"
          height="640"
          loading="lazy"
          decoding="async"
        />
      </div>
 
      <!-- Numéro de téléphone -->
      <a
        href={`tel:${PHONE}`}
        class="inline-block text-2xl md:text-3xl font-display font-bold text-cta hover:text-cta-hover transition-colors mb-6"
      >
        {PHONE_DISPLAY}
      </a>
 
      <!-- CTA -->
      <div class="flex justify-center mb-10">
        <a
          href={`tel:${PHONE}`}
          class="inline-flex items-center justify-center gap-2 bg-cta hover:bg-cta-hover text-cta-foreground font-body font-medium text-base px-8 py-4 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Appeler maintenant
        </a>
      </div>
 
      <p class="font-body text-muted-foreground text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        Avec une expérience solide dans le bien-être et les soins manuels, Laurianne vous accompagne avec professionnalisme et bienveillance. Chaque séance est un moment d'écoute, adapté à vos besoins spécifiques.
      </p>
 
      <!-- Qualités -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto">
        {qualities.map((q) => (
          <div class="flex flex-col items-center gap-2 p-4">
            <div class="w-12 h-12 rounded-full bg-sage-light flex items-center justify-center text-sage-dark" set:html={q.icon} />
            <span class="font-body font-medium text-foreground text-sm text-center">{q.text}</span>
          </div>
        ))}
      </div>
 
    </div>
  </div>
</section>